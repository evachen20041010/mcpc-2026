rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 只允許特定 email 寫入
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          "a0937510149@gmail.com",
          "nextgeneration1140331@gmail.com"
        ];
    }

    // 檢查最新消息 news 的資料格式
    function validNews() {
      let d = request.resource.data;

      return d.keys().hasOnly([
          "date",
          "category",
          "title",
          "desc",
          "timestamp",
          "updatedAt"
        ]) &&
        d.date is string &&
        d.date.matches("^\\d{4}\\.\\d{2}\\.\\d{2}$") &&
        d.category is string &&
        d.category in ["重要", "公告", "活動"] &&
        d.title is string &&
        d.title.size() > 0 &&
        d.title.size() <= 100 &&
        d.desc is string &&
        d.desc.size() > 0 &&
        d.desc.size() <= 8000 &&
        (!("timestamp" in d) || d.timestamp is timestamp) &&
        (!("updatedAt" in d) || d.updatedAt is timestamp);
    }

    // 檢查重要日程 timeline 的資料格式
    function validTimeline() {
      let d = request.resource.data;

      return d.keys().hasOnly([
          "dateStr",
          "title",
          "desc",
          "timestamp",
          "updatedAt"
        ]) &&
        d.dateStr is string &&
        d.dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
        d.title is string &&
        d.title.size() > 0 &&
        d.title.size() <= 100 &&
        (!("desc" in d) || d.desc is string && d.desc.size() <= 500) &&
        (!("timestamp" in d) || d.timestamp is timestamp) &&
        (!("updatedAt" in d) || d.updatedAt is timestamp);
    }

    match /news/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && validNews();
      allow delete: if isAdmin();
    }

    match /timeline/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && validTimeline();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
