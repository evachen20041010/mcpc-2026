<script>
  import { db } from "../../firebase/client.js";
  import { collection, getDocs, query, orderBy } from "firebase/firestore";

  type TimelineItem = {
    id: string;
    dateStr: string;
    title: string;
    desc: string;
  };

  const escapeMap: Record<string, string> = {
    "&": "&amp;",
    "<": "&lt;",
    ">": "&gt;",
    '"': "&quot;",
    "'": "&#39;",
  };

  const escapeHtml = (value: string | undefined = ""): string => {
    return String(value).replace(/[&<>"']/g, (char) => escapeMap[char] ?? char);
  };

  const getLocalDateString = () => {
    const now = new Date();
    const y = now.getFullYear();
    const m = String(now.getMonth() + 1).padStart(2, "0");
    const d = String(now.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  };

  const buildTimelineHtml = (
    items: TimelineItem[],
    today: string,
    activeIndex: number,
  ) => {
    let html = "";

    items.forEach((item, index) => {
      const dateStr = escapeHtml(item.dateStr);
      const title = escapeHtml(item.title);
      const desc = escapeHtml(item.desc);

      const isPast = item.dateStr < today;
      const isActive = activeIndex !== -1 && index === activeIndex;
      const isLast = index === items.length - 1;

      const dotClass = isActive
        ? "bg-primary border-white shadow-[0_0_0_6px_rgba(59,130,246,0.12),0_0_18px_rgba(59,130,246,0.35)]"
        : isPast
          ? "bg-slate-300 border-white"
          : "bg-white border-primary/50 shadow-[0_0_0_6px_rgba(59,130,246,0.08)]";

      const segClass = isPast
        ? "bg-gradient-to-b from-slate-200/80 via-slate-200/40 to-transparent"
        : isActive
          ? "bg-gradient-to-b from-primary/60 via-primary/20 to-transparent"
          : "bg-gradient-to-b from-slate-200 via-slate-200/55 to-transparent";

      const dateBadgeClass = isActive
        ? "bg-primary/10 text-primary border border-primary/15"
        : isPast
          ? "bg-slate-100 text-slate-500 border border-slate-200 line-through"
          : "bg-sky-50 text-sky-700 border border-sky-100";

      const cardClass = isActive
        ? "border-primary/25 shadow-[0_18px_40px_rgba(2,6,23,0.08)]"
        : isPast
          ? "border-slate-100"
          : "border-slate-200 group-hover:border-primary/25 group-hover:shadow-[0_18px_45px_rgba(2,6,23,0.10)]";

      const titleClass = isPast
        ? "text-slate-500 line-through"
        : "text-slate-800";
      const descClass = isPast ? "text-slate-400" : "text-slate-600";

      const statusPill = isActive
        ? `<span class="text-[11px] font-black tracking-widest text-primary bg-primary/10 border border-primary/15 px-2 py-1 rounded-full">NEXT</span>`
        : isPast
          ? `<span class="text-[11px] font-black tracking-widest text-slate-500 bg-slate-100 border border-slate-200 px-2 py-1 rounded-full">DONE</span>`
          : `<span class="text-[11px] font-black tracking-widest text-sky-700 bg-sky-50 border border-sky-100 px-2 py-1 rounded-full">UPCOMING</span>`;

      html += `
        <div class="group grid grid-cols-[28px_1fr] md:grid-cols-[36px_1fr] gap-6 items-start ${isPast ? "opacity-60" : ""}">
          <div class="flex flex-col items-center pt-2">
            <div class="w-3.5 h-3.5 rounded-full border-4 ${dotClass} transition-all duration-300"></div>
            ${isLast ? "" : `<div class="mt-4 w-px flex-1 min-h-[92px] ${segClass}"></div>`}
          </div>

          <div class="${isPast ? "" : "transition-transform duration-300 group-hover:-translate-y-0.5"}">
            <div class="flex items-center justify-between gap-3 mb-3">
              <span class="font-mono text-sm md:text-base font-bold px-3 py-1 rounded-xl inline-flex items-center ${dateBadgeClass}">
                ${dateStr.replace(/-/g, ".")}
              </span>
              ${statusPill}
            </div>

            <div class="bg-white border ${cardClass} p-5 md:p-6 rounded-2xl transition-all duration-300">
              <h4 class="text-lg md:text-xl font-black ${titleClass}">
                ${title}
              </h4>
              ${desc ? `<p class="mt-2 text-sm md:text-base leading-relaxed ${descClass}">${desc}</p>` : ""}
            </div>
          </div>
        </div>
      `;
    });

    return html;
  };

  const renderTimelineForRoot = async (root: HTMLElement) => {
    const containerEl = root.querySelector("[data-timeline-container]");
    if (!(containerEl instanceof HTMLElement)) return;

    const variant = root.dataset.variant ?? "full";

    try {
      const q = query(collection(db, "timeline"), orderBy("dateStr", "asc"));
      const querySnapshot = await getDocs(q);

      const allTimelines: TimelineItem[] = [];

      querySnapshot.forEach((doc) => {
        const data = doc.data() as {
          dateStr?: string;
          title?: string;
          desc?: string;
        };

        allTimelines.push({
          id: doc.id,
          dateStr: data.dateStr ?? "",
          title: data.title ?? "未命名日程",
          desc: data.desc ?? "",
        });
      });

      if (allTimelines.length === 0) {
        containerEl.innerHTML = `
          <div class="text-center text-slate-500 py-10">
            目前尚無日程資訊
          </div>
        `;
        return;
      }

      const today = getLocalDateString();
      let displayItems = [...allTimelines];
      let activeDisplayIndex = displayItems.findIndex(
        (item) => item.dateStr >= today,
      );

      if (variant === "overview") {
        const currentIndex = allTimelines.findIndex(
          (item) => item.dateStr >= today,
        );
        const BEFORE_COUNT = 2;
        const AFTER_COUNT = 2;
        const WINDOW_SIZE = BEFORE_COUNT + AFTER_COUNT + 1;

        let start = 0;
        let end = allTimelines.length;

        if (currentIndex === -1) {
          end = allTimelines.length;
          start = Math.max(0, end - WINDOW_SIZE);
        } else {
          start = Math.max(0, currentIndex - BEFORE_COUNT);
          end = Math.min(allTimelines.length, currentIndex + AFTER_COUNT + 1);

          const currentWindowSize = end - start;
          if (currentWindowSize < WINDOW_SIZE) {
            const missing = WINDOW_SIZE - currentWindowSize;
            if (start === 0) {
              end = Math.min(allTimelines.length, end + missing);
            } else if (end === allTimelines.length) {
              start = Math.max(0, start - missing);
            }
          }
        }

        displayItems = allTimelines.slice(start, end);
        activeDisplayIndex = displayItems.findIndex(
          (item) => item.dateStr >= today,
        );
      }

      containerEl.innerHTML = buildTimelineHtml(
        displayItems,
        today,
        activeDisplayIndex,
      );
    } catch (error) {
      console.error("Error loading timeline:", error);
      containerEl.innerHTML = `
        <div class="text-center text-rose-500 py-10">
          載入日程失敗，請重新整理頁面。
        </div>
      `;
    }
  };

  const initRulesContentTimelines = async () => {
    const roots = document.querySelectorAll("[data-rules-content]");
    for (const root of roots) {
      if (root instanceof HTMLElement) {
        await renderTimelineForRoot(root);
      }
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initRulesContentTimelines);
  } else {
    initRulesContentTimelines();
  }
</script>

