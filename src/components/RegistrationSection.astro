---
// 報名流程步驟資料 (保持不變)
const steps = [
  { step: "01", title: "詳閱簡章", desc: "請先下載競賽簡章，確認所有參賽規定與時程。" },
  { step: "02", title: "填寫報名表", desc: "至線上系統填寫隊伍資料、參賽組別與指導教授資訊。" },
  { step: "03", title: "上傳文件", desc: "將企劃書及授權書簽名掃描後，轉存 PDF 檔上傳。" },
  { step: "04", title: "完成報名", desc: "送出表單後留意收信，收到確認信即代表報名成功。" },
];
---

<section id="registration" class="py-20 bg-bg-light relative overflow-hidden">
  
  <div class="absolute top-0 right-0 w-96 h-96 bg-blue-100/40 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-sky-100/40 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
        報名專區
        <span class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full"></span>
      </h2>
      <p class="text-slate-600 mt-4 text-lg">簡單四步驟，展現您的創新實力</p>
    </div>

    <div class="grid md:grid-cols-4 gap-8 mb-16">
      {steps.map((item) => (
        <div class="bg-white rounded-3xl p-8 text-center shadow-[0_4px_20px_rgba(0,0,0,0.03)] border border-slate-100 relative group hover:-translate-y-2 transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] hover:border-primary/20">
          <div class="w-20 h-20 mx-auto bg-blue-50 text-primary rounded-2xl flex items-center justify-center text-3xl font-bold mb-6 group-hover:bg-primary group-hover:text-white transition-colors duration-500">
            {item.step}
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-3">{item.title}</h3>
          <p class="text-slate-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center">
      
      <a 
        href="https://docs.google.com/forms/..." 
        target="_blank" 
        class="group relative inline-flex items-center justify-center gap-4 px-12 py-5 bg-gradient-to-r from-primary to-blue-600 text-white text-xl font-bold rounded-full shadow-xl shadow-primary/30 hover:shadow-2xl hover:shadow-primary/40 hover:-translate-y-1 transition-all duration-300 overflow-hidden mb-12"
      >
        <div class="absolute inset-0 bg-white/20 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
        <span class="relative z-10">前往線上報名系統</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 relative z-10 transition-transform duration-300 group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      
      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-2xl p-6 border border-primary/10 shadow-sm flex flex-col md:flex-row items-start md:items-center gap-5 text-left transition-shadow hover:shadow-md">
            <div class="w-14 h-14 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-2xl flex-shrink-0">
                💡
            </div>
            <div>
                 <h4 class="text-lg font-bold text-slate-800 mb-2">報名狀態查詢說明</h4>
                 <p class="text-slate-600 leading-relaxed">
                    完成報名後，系統將自動寄發確認信。如需查詢報名進度或修改資料，請來信 
                    <a href="mailto:mcpc2026@example.edu.tw" class="text-primary font-bold hover:underline transition-colors">
                      mcpc2026@example.edu.tw
                    </a>，並於信中註明您的「隊伍名稱」與「隊長姓名」，我們將盡快為您查詢。
                </p>
            </div>
        </div>
      </div>

    </div>
  </div>
</section>