---
// 取得目前網址路徑，用來判斷哪個選項要亮起
const pathname = Astro.url.pathname;

const links = [
  { name: "首頁", href: "/" },
  { name: "競賽辦法", href: "/rules" }, // 假設您的頁面路徑
  { name: "報名專區", href: "/registration" },
  { name: "檔案下載", href: "/downloads" },
  { name: "交通地點", href: "/venue" },
  { name: "聯絡我們", href: "/contact" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-100 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20"> <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold tracking-tight">
          <span class="text-blue-700">2026</span>
          <span class="bg-gradient-to-r from-blue-600 to-sky-500 bg-clip-text text-transparent">行動通訊實務競賽</span>
        </a>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          {links.map((link) => {
            // 判斷是否為當前頁面 (首頁需完全匹配，其他頁面只要開頭匹配即可)
            const isActive = link.href === '/' ? pathname === '/' : pathname.startsWith(link.href);
            
            return (
              <a 
                href={link.href} 
                class:list={[
                  "text-base font-medium transition-colors relative py-2 group",
                  isActive ? "text-blue-700" : "text-slate-600 hover:text-blue-600"
                ]}
              >
                {link.name}
                
                {/* 底部線條 (Active 狀態顯示實線，Hover 狀態顯示動畫線) */}
                {isActive ? (
                  <span class="absolute bottom-0 left-0 w-full h-[3px] bg-sky-500 rounded-full shadow-sm shadow-sky-200"></span>
                ) : (
                  // 非當前頁面：Hover 時滑出的底線
                  <span class="absolute bottom-0 left-0 w-0 h-[3px] bg-sky-300 rounded-full transition-all duration-300 group-hover:w-full opacity-50"></span>
                )}
              </a>
            )
          })}
        </div>
      </div>

      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" type="button" class="text-slate-600 hover:text-blue-600 p-2 focus:outline-none">
          <span class="sr-only">開啟選單</span>
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 absolute w-full left-0 shadow-lg">
    <div class="px-4 pt-2 pb-6 space-y-1">
      {links.map((link) => {
         const isActive = link.href === '/' ? pathname === '/' : pathname.startsWith(link.href);
         return (
         <a href="/" class="text-2xl font-bold tracking-tight group">
        <span class="text-blue-700">2026</span>
        <span class="bg-gradient-to-r from-blue-600 to-sky-500 bg-clip-text text-transparent group-hover:from-blue-700 group-hover:to-sky-600 transition-all">
            行動通訊實務競賽
        </span>
        </a>

        <div class="ml-10 flex items-baseline space-x-8">
        {links.map((link) => {
            const isActive = link.href === '/' ? pathname === '/' : pathname.startsWith(link.href);
            return (
            <a 
                href={link.href} 
                class:list={[
                "text-base font-medium transition-colors relative py-2 group",
                // 當前頁面：深藍色；非當前：灰色 -> 懸停變藍色
                isActive ? "text-blue-700" : "text-slate-600 hover:text-blue-600"
                ]}
            >
                {link.name}
                
                {/* 修正：把原本的橘色底線改成 sky-500 (天藍色) */}
                {isActive ? (
                <span class="absolute bottom-0 left-0 w-full h-[3px] bg-sky-500 rounded-full shadow-sm shadow-sky-200"></span>
                ) : (
                <span class="absolute bottom-0 left-0 w-0 h-[3px] bg-sky-300 rounded-full transition-all duration-300 group-hover:w-full opacity-50"></span>
                )}
            </a>
            )
        })}
        </div>
         )
      })}
    </div>
  </div>
</nav>

<script>
  // 處理手機版選單開關
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>