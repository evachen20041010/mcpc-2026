---
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  return currentPath === path || currentPath.startsWith(`${path}/`);
};

const themeLinks = [
  {
    href: "/themes/energy-iot",
    label: "智慧節能與物聯網應用組",
  },
  {
    href: "/themes/intelligent-transport-security",
    label: "智慧指向性傳輸通訊網路與資訊安全組",
  },
  {
    href: "/themes/digital-application",
    label: "智慧數位應用組",
  },
];

const uploadLinks = [
  {
    href: "/upload/register",
    label: "線上報名",
  },
  {
    href: "/upload/preliminary",
    label: "初賽資料上傳",
  },
  {
    href: "/upload/final",
    label: "決賽資料上傳",
  },
];

const navLinks = [
  {
    href: "/",
    label: "首頁",
  },
  {
    href: "/news",
    label: "最新消息",
  },
  {
    href: "/rules",
    label: "競賽辦法",
  },
  {
    href: "/downloads",
    label: "檔案下載",
  },
  {
    href: "/venue",
    label: "交通地點",
  },
];

const isThemeActive = themeLinks.some((link) => isActive(link.href));
const isUploadActive = uploadLinks.some((link) => isActive(link.href));
---

<nav
  id="main-navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200 shadow-sm"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a
          href="/"
          class="flex items-baseline text-xl lg:text-2xl font-bold text-primary cursor-pointer"
        >
          2026 MCPC
          <span
            class="font-bold text-slate-500 text-[1rem] ml-2.5 tracking-wide"
          >
            | 行動通訊實務競賽
          </span>
        </a>
      </div>

      <div class="hidden lg:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`relative text-base font-bold transition-colors duration-300 ${
                isActive(link.href)
                  ? "text-primary"
                  : "text-slate-700 hover:text-primary"
              }`}
            >
              {link.label}
              <span
                class={`absolute left-0 -bottom-2 h-[3px] rounded-full bg-primary transition-all duration-300 ${
                  isActive(link.href) ? "w-full" : "w-0 group-hover:w-full"
                }`}
              />
            </a>
          ))
        }

        <div class="relative group" data-theme-root>
          <button
            type="button"
            class={`relative flex items-center gap-1 text-base font-bold transition-colors duration-300 ${
              isThemeActive
                ? "text-primary"
                : "text-slate-700 hover:text-primary"
            }`}
            data-theme-button
          >
            競賽主題資訊
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>

            <span
              class={`absolute left-0 -bottom-2 h-[3px] rounded-full bg-primary transition-all duration-300 ${
                isThemeActive ? "w-full" : "w-0 group-hover:w-full"
              }`}></span>
          </button>

          <div
            class="absolute right-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300"
            data-theme-menu
          >
            <div
              class="w-80 bg-white border border-slate-200 rounded-2xl shadow-xl p-3"
            >
              {
                themeLinks.map((link) => (
                  <a
                    href={link.href}
                    class={`block rounded-xl px-4 py-3 text-sm font-bold transition-colors ${
                      isActive(link.href)
                        ? "bg-primary/10 text-primary"
                        : "text-slate-700 hover:bg-slate-50 hover:text-primary"
                    }`}
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <div class="relative group" data-upload-root>
          <button
            type="button"
            class={`relative flex items-center gap-1 text-base font-bold transition-colors duration-300 ${
              isUploadActive
                ? "text-primary"
                : "text-slate-700 hover:text-primary"
            }`}
            data-upload-button
          >
            報名 / 資料上傳
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>

            <span
              class={`absolute left-0 -bottom-2 h-[3px] rounded-full bg-primary transition-all duration-300 ${
                isUploadActive ? "w-full" : "w-0 group-hover:w-full"
              }`}></span>
          </button>

          <div
            class="absolute right-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300"
            data-upload-menu
          >
            <div
              class="w-56 bg-white border border-slate-200 rounded-2xl shadow-xl p-3"
            >
              {
                uploadLinks.map((link) => (
                  <a
                    href={link.href}
                    class={`block rounded-xl px-4 py-3 text-sm font-bold transition-colors ${
                      isActive(link.href)
                        ? "bg-primary/10 text-primary"
                        : "text-slate-700 hover:bg-slate-50 hover:text-primary"
                    }`}
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <button
        id="mobile-menu-button"
        type="button"
        class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-xl border border-slate-200 text-slate-700 hover:text-primary hover:border-primary/30 transition-colors"
        aria-label="開啟選單"
        aria-expanded="false"
      >
        <svg
          id="mobile-menu-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white border-t border-slate-200 shadow-lg"
  >
    <div class="px-4 py-4 space-y-2">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`block rounded-xl px-4 py-3 text-base font-bold transition-colors ${
              isActive(link.href)
                ? "bg-primary/10 text-primary"
                : "text-slate-700 hover:bg-slate-50 hover:text-primary"
            }`}
          >
            {link.label}
          </a>
        ))
      }

      <div class="pt-2">
        <button
          type="button"
          class={`w-full flex items-center justify-between rounded-xl px-4 py-3 text-base font-bold transition-colors ${
            isThemeActive
              ? "bg-primary/10 text-primary"
              : "text-slate-700 hover:bg-slate-50 hover:text-primary"
          }`}
          data-mobile-theme-toggle
        >
          競賽主題資訊
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 transition-transform duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            data-mobile-theme-icon
          >
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </button>

        <div class="hidden pl-4 mt-2 space-y-2" data-mobile-theme-panel>
          {
            themeLinks.map((link) => (
              <a
                href={link.href}
                class={`block rounded-xl px-4 py-3 text-sm font-bold transition-colors ${
                  isActive(link.href)
                    ? "bg-primary/10 text-primary"
                    : "text-slate-600 hover:bg-slate-50 hover:text-primary"
                }`}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="pt-2">
        <button
          type="button"
          class={`w-full flex items-center justify-between rounded-xl px-4 py-3 text-base font-bold transition-colors ${
            isUploadActive
              ? "bg-primary/10 text-primary"
              : "text-slate-700 hover:bg-slate-50 hover:text-primary"
          }`}
          data-mobile-upload-toggle
        >
          報名 / 資料上傳
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 transition-transform duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            data-mobile-upload-icon
          >
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </button>

        <div class="hidden pl-4 mt-2 space-y-2" data-mobile-upload-panel>
          {
            uploadLinks.map((link) => (
              <a
                href={link.href}
                class={`block rounded-xl px-4 py-3 text-sm font-bold transition-colors ${
                  isActive(link.href)
                    ? "bg-primary/10 text-primary"
                    : "text-slate-600 hover:bg-slate-50 hover:text-primary"
                }`}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuIcon = document.getElementById("mobile-menu-icon");

  mobileMenuButton?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");

    mobileMenu?.classList.toggle("hidden");
    mobileMenuButton.setAttribute("aria-expanded", String(!isOpen));

    if (mobileMenuIcon) {
      mobileMenuIcon.innerHTML = isOpen
        ? '<path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"></path>'
        : '<path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>';
    }
  });

  const mobileThemeToggle = document.querySelector(
    "[data-mobile-theme-toggle]",
  );
  const mobileThemePanel = document.querySelector("[data-mobile-theme-panel]");
  const mobileThemeIcon = document.querySelector("[data-mobile-theme-icon]");

  mobileThemeToggle?.addEventListener("click", () => {
    mobileThemePanel?.classList.toggle("hidden");
    mobileThemeIcon?.classList.toggle("rotate-180");
  });

  const mobileUploadToggle = document.querySelector(
    "[data-mobile-upload-toggle]",
  );
  const mobileUploadPanel = document.querySelector(
    "[data-mobile-upload-panel]",
  );
  const mobileUploadIcon = document.querySelector("[data-mobile-upload-icon]");

  mobileUploadToggle?.addEventListener("click", () => {
    mobileUploadPanel?.classList.toggle("hidden");
    mobileUploadIcon?.classList.toggle("rotate-180");
  });
</script>
