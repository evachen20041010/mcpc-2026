---
// 取得目前網址路徑，用來判斷哪個選項要亮起
const pathname = Astro.url.pathname;

const links = [
  { name: "首頁", href: "/" },
  { name: "競賽辦法", href: "/rules" },
  { name: "報名專區", href: "/registration" },
  { name: "檔案下載", href: "/downloads" },
  { name: "交通地點", href: "/venue" },
  { name: "聯絡我們", href: "/contact" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold tracking-tight group flex items-center gap-2">
          <span class="text-primary group-hover:text-primary-dark transition-colors">2026 MCPC</span>
          <span class="text-slate-500 text-sm font-medium mt-1 hidden lg:block group-hover:text-primary transition-colors">| 行動通訊實務競賽</span>
        </a>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          {links.map((link) => {
            // 判斷是否為當前頁面
            const isActive = link.href === '/' ? pathname === '/' : pathname.startsWith(link.href);
            
            return (
              <a 
                href={link.href} 
                class:list={[
                  "text-base font-medium transition-colors relative py-2 group",
                  // 尚未選取是深灰色，Hover 變主色 (primary)
                  isActive ? "text-primary" : "text-slate-600 hover:text-primary"
                ]}
              >
                {link.name}
                
                {/* 底部線條 (改成 Banner 色系) */}
                {isActive ? (
                  // 當前頁面：顯示實線 (Primary Blue)
                  <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary rounded-full"></span>
                ) : (
                  // Hover 動畫：滑鼠移上去時展開 (Primary Blue with Opacity)
                  <span class="absolute bottom-0 left-0 w-0 h-[3px] bg-primary/60 rounded-full transition-all duration-300 group-hover:w-full"></span>
                )}
              </a>
            )
          })}
        </div>
      </div>

      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" type="button" class="text-slate-600 hover:text-primary p-2 focus:outline-none transition-colors">
          <span class="sr-only">開啟選單</span>
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 absolute w-full left-0 shadow-lg">
    <div class="px-4 pt-2 pb-6 space-y-1">
      {links.map((link) => {
         const isActive = link.href === '/' ? pathname === '/' : pathname.startsWith(link.href);
         return (
          <a
            href={link.href}
            class:list={[
              "block px-3 py-3 rounded-lg text-base font-medium transition-colors",
              // 手機版：選取時背景變淡藍色 (bg-light)，文字變主色 (primary)
              isActive ? "bg-bg-light text-primary" : "text-slate-600 hover:bg-slate-50 hover:text-primary"
            ]}
          >
            {link.name}
          </a>
         )
      })}
    </div>
  </div>
</nav>

<script>
  // 處理手機版選單開關
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>