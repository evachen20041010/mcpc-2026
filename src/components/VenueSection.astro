---
const transportMethods = [
  {
    title: "搭乘捷運",
    desc: "至「科技大樓站」下車，由 2 號出口出站，沿科技路步行約 8 分鐘即可抵達。",
    icon: "M12 2c-4 0-8 .5-8 4v9.5c0 .95.38 1.81 1 2.44V20c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h8v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-2.06c.62-.63 1-1.49 1-2.44V6c0-3.5-3.58-4-8-4zm3.5 12c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm-7 0c-.83 0-1.5-.67-1.5-1.5S6.67 11 7.5 11s1.5.67 1.5 1.5S8.33 14 7.5 14zm8.5-6H8V6h8v2z",
    bgClass: "bg-blue-600"
  },
  {
    title: "搭乘公車",
    desc: "搭乘 15、18、74、235 路公車至「國立科大站」下車。",
    icon: "M4 16c0 .88.39 1.67 1 2.22V20a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-1h8v1a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-1.78c.61-.55 1-1.34 1-2.22V6c0-3.5-3.58-4-8-4s-8 .5-8 4v10zm3.5 1c-.83 0-1.5-.67-1.5-1.5S6.67 14 7.5 14s1.5.67 1.5 1.5S8.33 17 7.5 17zm9 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11V6h14v5H5z",
    bgClass: "bg-sky-500"
  },
  {
    title: "自行開車",
    desc: "校內設有訪客停車場（每小時 $40），請由正門進入換證。",
    icon: "M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z",
    bgClass: "bg-indigo-500"
  }
];
---

<section id="venue" class="py-20 bg-slate-50 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#2E86AB 1px, transparent 1px); background-size: 30px 30px;"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
        交通與地點
        <span class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full"></span>
      </h2>
    </div>

    <div class="bg-white rounded-[2rem] p-8 lg:p-12 shadow-lg border border-slate-100 overflow-hidden">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        <div class="space-y-10">
          
          <div class="border-l-4 border-primary pl-6">
            <h3 class="text-3xl font-bold text-slate-800 mb-2">國立科技大學</h3>
            <p class="text-xl text-primary font-bold tracking-wide">工程館 2F 國際會議廳</p>
            <p class="text-slate-500 mt-2 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                台北市大安區科技路 100 號
            </p>
          </div>

          <div class="space-y-6">
            {transportMethods.map((method) => (
              <div class="group flex items-start gap-5 p-4 rounded-2xl transition-colors hover:bg-slate-50">
                <div class={`w-14 h-14 ${method.bgClass} rounded-2xl flex items-center justify-center text-white shadow-md shadow-blue-100 flex-shrink-0 group-hover:scale-110 transition-transform duration-300`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                    <path d={method.icon} />
                  </svg>
                </div>
                
                <div>
                  <h4 class="text-lg font-bold text-slate-800 mb-1 group-hover:text-primary transition-colors">{method.title}</h4>
                  <p class="text-sm text-slate-600 leading-relaxed opacity-90">{method.desc}</p>
                </div>
              </div>
            ))}
          </div>

        </div>

        <div class="h-[450px] bg-slate-100 rounded-[2rem] overflow-hidden relative shadow-inner border border-slate-200 group">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3615.002773410724!2d121.5398283!3d25.033976!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3442a7f607149029%3A0x6b44782071d5055b!2z5ZyL56uL6Ie654Gj56eR5oqA5aSn5a24!5e0!3m2!1szh-TW!2stw!4v1700000000000!5m2!1szh-TW!2stw" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy"
            class="grayscale-[20%] group-hover:grayscale-0 transition-all duration-500"
          ></iframe>
          
          <div class="absolute bottom-6 left-6 bg-white/95 backdrop-blur px-5 py-3 rounded-xl shadow-lg border border-slate-100 flex items-center gap-3 animate-float">
            <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
            <div>
                <p class="text-xs text-slate-500 font-bold uppercase">Location</p>
                <p class="text-sm font-bold text-slate-800">競賽會場位置</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>