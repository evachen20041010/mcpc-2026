---
import { venueData } from "../data/venueData";

interface Props {
  standalone?: boolean;
}

const { standalone = false } = Astro.props;
---

<section
  id="venue"
  class:list={[
    "relative overflow-hidden",
    standalone ? "py-20 bg-slate-50" : "py-20 bg-slate-50",
  ]}
>
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(#2E86AB 1px, transparent 1px); background-size: 30px 30px;"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    {
      !standalone && (
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
            交通與地點
            <span class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full" />
          </h2>
        </div>
      )
    }

    <div
      class="bg-white rounded-[2rem] p-8 lg:p-12 shadow-lg border border-slate-100 overflow-hidden"
    >
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-10">
          <div class="border-l-4 border-primary pl-6">
            <h3 class="text-3xl font-bold text-slate-800 mb-2">
              {venueData.schoolName}
            </h3>
            <p class="text-xl text-primary font-bold tracking-wide">
              {venueData.buildingName}
            </p>
            <p class="text-slate-500 mt-2 flex items-center gap-2">
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              {venueData.address}
            </p>
          </div>

          <div class="space-y-4">
            {
              venueData.transportMethods.map((method) => (
                <div class="group flex items-start gap-4 p-4 rounded-2xl transition-colors hover:bg-slate-50 border border-transparent hover:border-slate-100">
                  <div
                    class={`w-14 h-14 mt-1 ${method.bgClass} rounded-2xl flex items-center justify-center shadow-md shadow-blue-100 flex-shrink-0 group-hover:scale-110 transition-transform duration-300`}
                  >
                    <img
                      src={method.iconSrc}
                      alt={method.title}
                      class="w-7 h-7 object-contain"
                      style="filter: brightness(0) invert(1);"
                    />
                  </div>

                  <div class="pt-1 flex-1">
                    <h4 class="text-lg font-bold text-slate-800 mb-1.5 group-hover:text-primary transition-colors">
                      {method.title}
                    </h4>
                    <p
                      class="text-sm text-slate-600 leading-relaxed opacity-90"
                      set:html={method.desc}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="h-[500px] bg-slate-100 rounded-[2rem] overflow-hidden relative shadow-inner border border-slate-200 group"
        >
          <iframe
            src={venueData.mapEmbedUrl}
            width="600"
            height="450"
            style="border:0; width:100%; height:100%;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={venueData.mapTitle}></iframe>

          <div
            class="absolute bottom-6 left-6 bg-white/95 backdrop-blur px-5 py-3 rounded-xl shadow-lg border border-slate-100 flex items-center gap-3 animate-float"
          >
            <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
            <div>
              <p class="text-xs text-slate-500 font-bold uppercase">Location</p>
              <p class="text-sm font-bold text-slate-800">
                {venueData.mapTitle}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
