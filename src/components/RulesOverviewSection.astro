---
const themes = [
  {
    title: "智慧節能與物聯網應用組",
    items: [
      "主軸一、AI 模型服務平台於智慧節能或設備管理的應用（使用「高效率節能人工智慧模型服務平台」開發）",
      "主軸二、智慧物聯網技術開發（使用「B5G AIoT 智慧農業平台」開發）",
    ],
    iconBg: "bg-emerald-50",
    decorationBg: "bg-emerald-50",
    iconSrc: "/images/internet.png",
  },
  {
    title: "智慧指向性傳輸暨通訊網路與資訊安全組",
    items: [
      "主軸一、低軌衛星通訊網路與資訊安全（使用「低軌衛星通訊網路與資訊安全」平台開發）",
      "主軸二、雙天線陣列智慧指向性傳輸與應用（使用「雙毫米波天線陣列平台」開發）",
    ],
    iconBg: "bg-purple-50",
    decorationBg: "bg-purple-50",
    iconSrc: "/images/hotspot.png",
  },
  {
    title: "智慧數位應用組",
    items: [
      "主軸一、智慧交通安全新生活（使用「5G-V2X 平台」進行開發）",
      "主軸二、即時智慧感知結合通訊應用（使用「B5G近海醫療衛星通訊整合平台」進行開發）",
    ],
    iconBg: "bg-sky-50",
    decorationBg: "bg-sky-50",
    iconSrc: "/images/virtual-reality.png",
  },
];

const organizers = [
  {
    label: "指導單位",
    value: "教育部、下世代行動通訊技術人才培育計畫辦公室",
  },
  {
    label: "主辦單位",
    value: "次世代超高速傳輸系統整合教學聯盟中心",
  },
  {
    label: "協辦單位",
    value:
      "國立中興大學、國立虎尾科技大學、國立陽明交通大學、國立清華大學、國立臺灣科技大學、元智大學、長庚大學",
  },
];
---

<section id="rules" class="py-24 bg-slate-50 relative overflow-hidden">
  <div
    class="absolute top-0 left-0 w-full h-24 bg-gradient-to-b from-white to-transparent opacity-50"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 animate-fade-up">
      <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
        競賽辦法
        <span
          class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full"
        ></span>
      </h2>
      <p class="mt-6 text-slate-600 max-w-2xl mx-auto leading-relaxed">
        完整規範、評審標準、獎勵與注意事項請前往詳情頁查看
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 mb-20">
      <div
        class="bg-white rounded-3xl p-8 lg:p-12 shadow-sm border border-slate-100 flex flex-col h-full relative overflow-hidden"
      >
        <div
          class="absolute -bottom-6 -right-6 opacity-[0.03] pointer-events-none"
        >
          <svg
            width="160"
            height="160"
            viewBox="0 0 160 160"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <pattern
              id="dots-overview"
              x="0"
              y="0"
              width="20"
              height="20"
              patternUnits="userSpaceOnUse"
            >
              <circle cx="2" cy="2" r="2" fill="#0f172a"></circle>
            </pattern>
            <rect width="160" height="160" fill="url(#dots-overview)"></rect>
          </svg>
        </div>

        <div
          class="absolute -bottom-12 -right-12 w-32 h-32 rounded-full border-[16px] border-primary/5 pointer-events-none"
        >
        </div>

        <h3 class="text-2xl font-bold text-slate-800 mb-8 relative z-10">
          競賽目的
        </h3>

        <div class="flex-grow relative z-10">
          <p class="text-slate-600 leading-loose text-lg">
            因應行動通訊技術演進及產業需求，將藉由建立以重點技術主題為核心的全國性跨校教學聯盟，發展推廣具跨層次系統整合特性之教學資源，並強化與國際趨勢及產業需求接軌，透過共享教學資源以提高我國大學校院下世代行動通訊技術教學能量，有效培育具系統觀及國際觀的行動通訊專業人才並將所學實務應用。本競賽將藉由教育部下世代行動通訊技術人才培育計畫所發展的五個平台，並規劃三大主題提供參賽者進行創意發想，不同的題目主軸使用不同平台進行開發，讓參賽團隊可以進行多元創新設計與應用。
          </p>
        </div>
      </div>

      <div
        class="bg-[#1a4f6e] rounded-3xl p-8 lg:p-12 shadow-lg border border-white/10 flex flex-col h-full"
      >
        <h3 class="text-2xl font-bold text-white mb-8">辦理單位</h3>
        <div class="flex-grow space-y-8">
          {
            organizers.map((item) => (
              <div>
                <p class="text-sky-400 text-sm font-bold uppercase tracking-widest mb-2">
                  {item.label}
                </p>
                <p class="text-white text-lg font-medium leading-relaxed">
                  {item.value}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h3 class="text-2xl font-bold text-slate-800">競賽主題</h3>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          themes.map((theme) => (
            <div class="bg-white rounded-[2rem] p-8 border border-slate-200 hover:border-primary/50 hover:shadow-xl transition-all duration-500 group flex flex-col h-full relative overflow-hidden">
              <div
                class={`absolute -bottom-10 -right-10 w-32 h-32 rounded-full ${theme.decorationBg} opacity-40 group-hover:scale-150 transition-transform duration-700`}
              />
              <div
                class={`w-14 h-14 ${theme.iconBg} rounded-2xl flex items-center justify-center mb-8 shadow-inner`}
              >
                <img
                  src={theme.iconSrc}
                  alt={theme.title}
                  class="w-7 h-7 object-contain"
                />
              </div>
              <h4 class="text-xl font-bold text-slate-800 mb-6 group-hover:text-primary transition-colors">
                {theme.title}
              </h4>
              <ul class="space-y-4 relative z-10 flex-grow">
                {theme.items.map((item) => (
                  <li class="text-base text-slate-600 leading-relaxed flex items-start">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary/40 mt-2 mr-3 shrink-0" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h3 class="text-2xl font-bold text-slate-800">參賽資格</h3>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>
      <div
        class="bg-white rounded-[2.5rem] p-8 lg:p-12 shadow-sm border border-slate-100 relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10 opacity-60"
        >
        </div>

        <div class="mb-10">
          <p
            class="text-xl text-slate-700 font-bold mb-4 flex items-center gap-3"
          >
            <span class="w-2 h-2 rounded-full bg-primary"></span>
            大專校院在校生 或 應屆（114學年度）畢業生組隊參加
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-slate-50/50 rounded-2xl p-8 border border-slate-100">
            <h4 class="text-lg font-bold text-primary mb-6 flex items-center">
              <i class="fa-solid fa-users text-sm"></i> 隊伍組成規定
            </h4>
            <ul class="space-y-4 text-slate-600 leading-relaxed">
              <li class="flex items-start gap-3">
                <span class="font-mono text-primary font-bold mt-0.5">01.</span>
                <p>
                  每所學校報名隊數<strong
                    class="text-slate-800 underline decoration-primary/30 decoration-4"
                    >不限</strong
                  >。
                </p>
              </li>
              <li class="flex items-start gap-3">
                <span class="font-mono text-primary font-bold mt-0.5">02.</span>
                <p>
                  每隊指導教師 <strong class="text-slate-800 font-black"
                    >1</strong
                  > 人，隊員 <strong class="text-slate-800 font-black"
                    >1 至 6</strong
                  > 人（開放跨校組隊）。
                </p>
              </li>
              <li class="flex items-start gap-3">
                <span class="font-mono text-primary font-bold mt-0.5">03.</span>
                <p>
                  需推派 <strong class="text-slate-800 font-black">1</strong> 位隊員擔任隊長，統籌報名與聯絡事宜。
                </p>
              </li>
            </ul>
          </div>

          <div class="bg-slate-50/50 rounded-2xl p-8 border border-slate-100">
            <h4 class="text-lg font-bold text-rose-500 mb-6 flex items-center">
              <i class="fa-solid fa-circle-exclamation text-sm"></i> 報名限制事項
            </h4>
            <ul class="space-y-6 text-slate-600 leading-relaxed">
              <li class="flex items-start gap-4">
                <span class="font-mono text-rose-500 font-bold mt-0.5">01.</span
                >
                <p>
                  每位學生僅可報名 <strong class="text-slate-800 font-black"
                    >1</strong
                  > 支隊伍。
                </p>
              </li>
              <li class="flex items-start gap-4">
                <span class="font-mono text-rose-500 font-bold mt-0.5">02.</span
                >
                <p>
                  每位指導教師至多指導 <strong class="text-slate-800 font-black"
                    >3</strong
                  > 支隊伍。
                </p>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h3 class="text-2xl font-bold text-slate-800">初賽</h3>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>
      <div
        class="bg-white rounded-[2.5rem] p-8 lg:p-12 shadow-sm border border-slate-100 relative overflow-hidden text-left"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10 opacity-60"
        >
        </div>

        <div class="mb-10">
          <p
            class="text-xl text-slate-700 font-bold mb-4 flex items-center gap-3"
          >
            <span class="w-2 h-2 rounded-full bg-primary"></span>
            初賽方式：文件審查
          </p>
          <div class="text-lg text-slate-600 leading-loose space-y-2 mb-10">
            <p>
              請於 <strong class="text-slate-900 font-bold"
                >115年10月6日(二) 中午12點前</strong
              > 上傳「提案企劃書+提案簡報」至競賽網頁。由評審委員依各參賽隊伍所繳交之提案企劃書與提案簡報進行評選。
            </p>
            <p>
              每項競賽主題擇優選出晉級隊伍，並於 <strong
                class="text-slate-900 font-bold">115年11月2日(一)</strong
              > 在競賽網頁公告入圍名單。
            </p>
          </div>

          <h4
            class="text-lg font-bold text-slate-800 mb-4 border-l-4 border-primary pl-3"
          >
            各組預計晉級決賽隊數
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div
              class="border border-slate-100 rounded-xl p-6 flex flex-col justify-center items-center bg-slate-50/50 text-center gap-3"
            >
              <span class="text-slate-700 font-bold text-base leading-snug">
                智慧節能與物聯網<br />應用組
              </span>
              <div class="w-8 h-px bg-slate-200"></div>
              <span class="text-primary font-black text-3xl">
                10 <span class="text-sm font-bold text-slate-500 ml-1">隊</span>
              </span>
            </div>

            <div
              class="border border-slate-100 rounded-xl p-6 flex flex-col justify-center items-center bg-slate-50/50 text-center gap-3"
            >
              <span class="text-slate-700 font-bold text-base leading-snug">
                智慧指向性傳輸暨<br />通訊網路與資訊安全組
              </span>
              <div class="w-8 h-px bg-slate-200"></div>
              <span class="text-primary font-black text-3xl">
                10 <span class="text-sm font-bold text-slate-500 ml-1">隊</span>
              </span>
            </div>

            <div
              class="border border-slate-100 rounded-xl p-6 flex flex-col justify-center items-center bg-slate-50/50 text-center gap-3"
            >
              <span class="text-slate-700 font-bold text-base leading-snug">
                智慧數位<br />應用組
              </span>
              <div class="w-8 h-px bg-slate-200"></div>
              <span class="text-primary font-black text-3xl">
                10 <span class="text-sm font-bold text-slate-500 ml-1">隊</span>
              </span>
            </div>
          </div>
        </div>

        <div
          class="bg-amber-50/50 rounded-2xl p-6 border border-amber-100 text-left"
        >
          <h4 class="text-lg font-bold text-amber-700 mb-2">注意事項</h4>
          <p class="text-slate-600 leading-relaxed text-base">
            入圍作品隊數由「競賽評審委員會議」依參賽隊伍數量差異、各項主題性質不同、主題難易度與作品優異情形議定，必要時可從缺、調整或減少隊數。
          </p>
        </div>
      </div>
    </div>

    <div class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h3 class="text-2xl font-bold text-slate-800">決賽</h3>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>
      <div
        class="bg-white rounded-[2.5rem] p-8 lg:p-12 shadow-sm border border-slate-100 relative overflow-hidden text-left"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10 opacity-60"
        >
        </div>
        <div class="mb-10">
          <p
            class="text-xl text-slate-700 font-bold mb-4 flex items-center gap-3"
          >
            <span class="w-2 h-2 rounded-full bg-primary"></span>
            決賽方式：實地測試
          </p>
          <div class="text-lg text-slate-600 leading-loose">
            <p class="mb-6">
              由評審委員實地評分，並於決賽現場進行展示及詢答。入圍隊伍須於 <strong
                class="text-slate-900 font-bold"
                >115年12月2日(一) 下午5點前</strong
              > 完成以下資料上傳：
            </p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div
                class="flex items-center gap-3 bg-slate-50/50 p-4 rounded-xl border border-slate-100"
              >
                <span class="w-2 h-2 rounded-full bg-primary/60 shrink-0"
                ></span>
                <span class="font-bold text-slate-700">決賽簡報</span>
              </div>
              <div
                class="flex items-center gap-3 bg-slate-50/50 p-4 rounded-xl border border-slate-100"
              >
                <span class="w-2 h-2 rounded-full bg-primary/60 shrink-0"
                ></span>
                <span class="font-bold text-slate-700">作品設計與測試文件</span>
              </div>
              <div
                class="flex items-center gap-3 bg-slate-50/50 p-4 rounded-xl border border-slate-100"
              >
                <span class="w-2 h-2 rounded-full bg-primary/60 shrink-0"
                ></span>
                <span class="font-bold text-slate-700"
                  >3-5 分鐘作品介紹與成果展示影片</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div
            class="bg-slate-50 p-8 rounded-[2rem] border border-slate-100 flex flex-col justify-center"
          >
            <h4
              class="text-lg font-bold text-slate-800 mb-4 border-b border-slate-200 pb-4"
            >
              隊員更換申請
            </h4>
            <p class="text-slate-600 text-base leading-loose">
              入圍晉級決賽名單公布後，若根據實際狀況須更換隊員者，最晚應於 <strong
                class="text-slate-900">115年11月6日(五) 下午5點前</strong
              > 填妥「隊員更換申請表」向主辦單位提出申請核備。逾期提出申請者，概不受理。
            </p>
          </div>

          <div class="bg-primary/5 rounded-[2rem] p-8 border border-primary/10">
            <h4 class="text-lg font-bold text-primary mb-6">活動資訊</h4>
            <div class="space-y-6 text-left">
              <div class="flex items-center gap-5">
                <div
                  class="w-12 h-12 rounded-full bg-white flex items-center justify-center shadow-sm shrink-0 border border-primary/20"
                >
                  <img
                    src="/images/calendar.png"
                    alt="日期"
                    class="w-6 h-6 object-contain"
                  />
                </div>
                <div>
                  <p
                    class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-1"
                  >
                    決賽日期
                  </p>
                  <p class="text-lg font-bold text-slate-800">
                    115 年 12 月 12 日 (六)
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-5 text-left">
                <div
                  class="w-12 h-12 rounded-full bg-white flex items-center justify-center shadow-sm shrink-0 border border-primary/20"
                >
                  <img
                    src="/images/location.png"
                    alt="地點"
                    class="w-6 h-6 object-contain"
                  />
                </div>
                <div>
                  <p
                    class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-1"
                  >
                    決賽地點
                  </p>
                  <p class="text-lg font-bold text-slate-800">
                    國立中興大學電機工程系 <span
                      class="text-sm font-normal text-slate-500">(1 樓)</span
                    >
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h3 class="text-2xl font-bold text-slate-800">重要日程</h3>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>

      <div
        class="bg-white rounded-[2.5rem] p-8 lg:p-12 shadow-sm border border-slate-100 relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10 opacity-60"
        >
        </div>

        <div class="max-w-3xl mx-auto">
          <div
            id="rules-overview-timeline-container"
            class="relative space-y-10 py-2"
          >
            <div
              class="grid grid-cols-[28px_1fr] md:grid-cols-[36px_1fr] gap-6 items-start animate-pulse"
            >
              <div class="flex flex-col items-center pt-2">
                <div class="w-3.5 h-3.5 rounded-full bg-slate-200"></div>
                <div class="mt-4 w-px flex-1 min-h-[92px] bg-slate-200/60">
                </div>
              </div>
              <div class="space-y-4">
                <div class="h-7 bg-slate-200 rounded-xl w-32"></div>
                <div
                  class="h-24 bg-slate-100 rounded-2xl w-full border border-slate-100"
                >
                </div>
              </div>
            </div>

            <div
              class="grid grid-cols-[28px_1fr] md:grid-cols-[36px_1fr] gap-6 items-start animate-pulse"
            >
              <div class="flex flex-col items-center pt-2">
                <div class="w-3.5 h-3.5 rounded-full bg-slate-200"></div>
                <div class="mt-4 w-px flex-1 min-h-[92px] bg-slate-200/60">
                </div>
              </div>
              <div class="space-y-4">
                <div class="h-7 bg-slate-200 rounded-xl w-40"></div>
                <div
                  class="h-24 bg-slate-100 rounded-2xl w-full border border-slate-100"
                >
                </div>
              </div>
            </div>

            <div
              class="grid grid-cols-[28px_1fr] md:grid-cols-[36px_1fr] gap-6 items-start animate-pulse"
            >
              <div class="flex flex-col items-center pt-2">
                <div class="w-3.5 h-3.5 rounded-full bg-slate-200"></div>
              </div>
              <div class="space-y-4">
                <div class="h-7 bg-slate-200 rounded-xl w-36"></div>
                <div
                  class="h-24 bg-slate-100 rounded-2xl w-full border border-slate-100"
                >
                </div>
              </div>
            </div>
          </div>
          <p
            class="mt-5 text-center text-xs sm:text-sm text-slate-400 leading-relaxed"
          >
            ※ 首頁僅顯示近期重要日程，完整時程請見競賽辦法。
          </p>
        </div>
      </div>
    </div>

    <div
      class="bg-white border border-slate-100 rounded-[2.5rem] p-8 lg:p-12 shadow-sm text-center"
    >
      <div class="max-w-3xl mx-auto">
        <p class="text-sm font-bold tracking-[0.25em] text-primary/80 mb-4">
          FULL DETAILS
        </p>
        <h3 class="text-3xl lg:text-4xl font-black text-slate-800 mb-4">
          查看完整競賽辦法
        </h3>
        <p class="text-slate-600 text-lg leading-relaxed mb-8">
          完整頁面包含評審標準、競賽獎勵、完整注意事項與更完整的說明內容。
        </p>
        <a
          href="/rules"
          class="inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-primary text-white font-bold tracking-[0.08em] transition-all duration-300 shadow-[0_12px_24px_rgba(26,79,110,0.2)] hover:shadow-[0_18px_30px_rgba(26,79,110,0.28)] hover:-translate-y-1"
        >
          前往詳情 →
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { db } from "../firebase/client.js";
  import { collection, getDocs, query, orderBy } from "firebase/firestore";

  type TimelineItem = {
    id: string;
    dateStr: string;
    title: string;
    desc: string;
  };

  const renderRulesOverviewTimeline = async () => {
    const containerEl = document.getElementById(
      "rules-overview-timeline-container",
    );
    if (!(containerEl instanceof HTMLElement)) return;

    const escapeMap: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    };

    const escapeHtml = (value: string | undefined = ""): string => {
      return String(value).replace(
        /[&<>"']/g,
        (char) => escapeMap[char] ?? char,
      );
    };

    const getLocalDateString = () => {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, "0");
      const d = String(now.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    };

    try {
      const q = query(collection(db, "timeline"), orderBy("dateStr", "asc"));
      const querySnapshot = await getDocs(q);

      const allTimelines: TimelineItem[] = [];

      querySnapshot.forEach((doc) => {
        const data = doc.data() as {
          dateStr?: string;
          title?: string;
          desc?: string;
        };

        allTimelines.push({
          id: doc.id,
          dateStr: data.dateStr ?? "",
          title: data.title ?? "未命名日程",
          desc: data.desc ?? "",
        });
      });

      if (allTimelines.length === 0) {
        containerEl.innerHTML = `
          <div class="text-center text-slate-500 py-10">
            目前尚無日程資訊
          </div>
        `;
        return;
      }

      const today = getLocalDateString();
      const currentIndex = allTimelines.findIndex(
        (item) => item.dateStr >= today,
      );

      const BEFORE_COUNT = 2;
      const AFTER_COUNT = 2;
      const WINDOW_SIZE = BEFORE_COUNT + AFTER_COUNT + 1;

      let start = 0;
      let end = allTimelines.length;

      if (currentIndex === -1) {
        end = allTimelines.length;
        start = Math.max(0, end - WINDOW_SIZE);
      } else {
        start = Math.max(0, currentIndex - BEFORE_COUNT);
        end = Math.min(allTimelines.length, currentIndex + AFTER_COUNT + 1);

        const currentWindowSize = end - start;
        if (currentWindowSize < WINDOW_SIZE) {
          const missing = WINDOW_SIZE - currentWindowSize;
          if (start === 0) {
            end = Math.min(allTimelines.length, end + missing);
          } else if (end === allTimelines.length) {
            start = Math.max(0, start - missing);
          }
        }
      }

      const displayItems = allTimelines.slice(start, end);
      const activeDisplayIndex = displayItems.findIndex(
        (item) => item.dateStr >= today,
      );

      let html = "";

      displayItems.forEach((item, index) => {
        const dateStr = escapeHtml(item.dateStr);
        const title = escapeHtml(item.title);
        const desc = escapeHtml(item.desc);

        const isPast = item.dateStr < today;
        const isActive =
          activeDisplayIndex !== -1 && index === activeDisplayIndex;
        const isLast = index === displayItems.length - 1;

        const dotClass = isActive
          ? "bg-primary border-white shadow-[0_0_0_6px_rgba(59,130,246,0.12),0_0_18px_rgba(59,130,246,0.35)]"
          : isPast
            ? "bg-slate-300 border-white"
            : "bg-white border-primary/50 shadow-[0_0_0_6px_rgba(59,130,246,0.08)]";

        const segClass = isPast
          ? "bg-gradient-to-b from-slate-200/80 via-slate-200/40 to-transparent"
          : isActive
            ? "bg-gradient-to-b from-primary/60 via-primary/20 to-transparent"
            : "bg-gradient-to-b from-slate-200 via-slate-200/55 to-transparent";

        const dateBadgeClass = isActive
          ? "bg-primary/10 text-primary border border-primary/15"
          : isPast
            ? "bg-slate-100 text-slate-500 border border-slate-200 line-through"
            : "bg-sky-50 text-sky-700 border border-sky-100";

        const cardClass = isActive
          ? "border-primary/25 shadow-[0_18px_40px_rgba(2,6,23,0.08)]"
          : isPast
            ? "border-slate-100"
            : "border-slate-200 group-hover:border-primary/25 group-hover:shadow-[0_18px_45px_rgba(2,6,23,0.10)]";

        const titleClass = isPast
          ? "text-slate-500 line-through"
          : "text-slate-800";
        const descClass = isPast ? "text-slate-400" : "text-slate-600";

        const statusPill = isActive
          ? `<span class="text-[11px] font-black tracking-widest text-primary bg-primary/10 border border-primary/15 px-2 py-1 rounded-full">NEXT</span>`
          : isPast
            ? `<span class="text-[11px] font-black tracking-widest text-slate-500 bg-slate-100 border border-slate-200 px-2 py-1 rounded-full">DONE</span>`
            : `<span class="text-[11px] font-black tracking-widest text-sky-700 bg-sky-50 border border-sky-100 px-2 py-1 rounded-full">UPCOMING</span>`;

        html += `
          <div class="group grid grid-cols-[28px_1fr] md:grid-cols-[36px_1fr] gap-6 items-start ${isPast ? "opacity-60" : ""}">
            <div class="flex flex-col items-center pt-2">
              <div class="w-3.5 h-3.5 rounded-full border-4 ${dotClass} transition-all duration-300"></div>
              ${isLast ? "" : `<div class="mt-4 w-px flex-1 min-h-[92px] ${segClass}"></div>`}
            </div>

            <div class="${isPast ? "" : "transition-transform duration-300 group-hover:-translate-y-0.5"}">
              <div class="flex items-center justify-between gap-3 mb-3">
                <span class="font-mono text-sm md:text-base font-bold px-3 py-1 rounded-xl inline-flex items-center ${dateBadgeClass}">
                  ${dateStr.replace(/-/g, ".")}
                </span>
                ${statusPill}
              </div>

              <div class="bg-white border ${cardClass} p-5 md:p-6 rounded-2xl transition-all duration-300">
                <h4 class="text-lg md:text-xl font-black ${titleClass}">
                  ${title}
                </h4>
                ${desc ? `<p class="mt-2 text-sm md:text-base leading-relaxed ${descClass}">${desc}</p>` : ""}
              </div>
            </div>
          </div>
        `;
      });

      containerEl.innerHTML = html;
    } catch (error) {
      console.error("Error loading rules overview timeline:", error);
      containerEl.innerHTML = `
        <div class="text-center text-rose-500 py-10">
          載入日程失敗，請重新整理頁面。
        </div>
      `;
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderRulesOverviewTimeline);
  } else {
    renderRulesOverviewTimeline();
  }
</script>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-up {
    animation: fadeUp 0.8s ease-out forwards;
  }
</style>
