      <div class="bg-white rounded-[2.5rem] p-8 lg:p-12 shadow-sm border border-slate-100 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-slate-50 rounded-bl-full -z-10 opacity-60"></div>

        <div class="max-w-3xl mx-auto">
          <div id="rules-overview-timeline-container" class="relative space-y-10 py-2">
