---
const news = [
  { date: "2026.03.01", category: "公告", title: "競賽報名正式開跑", desc: "2026 年度行動通訊實務競賽即日起開放報名，歡迎全國大專院校學生踴躍參加。" },
  { date: "2026.03.10", category: "活動", title: "競賽說明會場次公告", desc: "將於北中南三地舉辦線上說明會，詳細解說競賽規則與評分標準。" },
  { date: "2026.03.15", category: "重要", title: "新增競賽主題組別", desc: "今年新增「智慧數位應用組」，鼓勵參賽者結合 AI 與大數據技術。" },
];
---

<section id="news" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
        最新消息
        <span class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full"></span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {news.map((item) => (
        <div class="group bg-white border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm font-bold text-primary">{item.date}</span>
            <span class="text-xs font-medium px-2 py-1 bg-bg-light text-primary-dark rounded-full">{item.category}</span>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-primary transition-colors">{item.title}</h3>
          <p class="text-slate-600 mb-4 line-clamp-2">{item.desc}</p>
          <a href="#" class="inline-flex items-center text-sm font-bold text-primary hover:text-primary-dark">
            了解更多 <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>