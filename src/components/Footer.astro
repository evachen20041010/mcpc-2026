---
import { organizers } from "../data/rulesData";
---

<footer class="bg-slate-900 text-slate-300 py-12 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-[1.5fr_0.9fr_1fr] gap-12 mb-8">
      <div>
        <!-- <h3 class="text-white text-lg font-bold mb-6">辦理單位</h3> -->

        <div class="space-y-6">
          {
            organizers.map((item) => (
              <div>
                <h3 class="text-white text-lg font-bold mb-4">{item.label}</h3>

                {
                  Array.isArray(item.value) ? (
                    <div class="leading-relaxed flex flex-wrap gap-x-1 gap-y-1">
                      {item.value.map((unit, index) => (
                        <span class="inline-block whitespace-nowrap">
                          {unit}{index < item.value.length - 1 ? "、" : ""}
                        </span>
                      ))}
                    </div>
                  ) : (
                    <p class="eading-relaxed">{item.value}</p>
                  )
                }
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="text-white text-lg font-bold mb-4">快速連結</h3>
        <ul class="space-y-2">
          <li>
            <a href="/" class="hover:text-primary transition-colors">首頁</a>
          </li>
          <li>
            <a href="/news" class="hover:text-primary transition-colors"
              >最新消息</a
            >
          </li>
          <li>
            <a href="/rules" class="hover:text-primary transition-colors"
              >競賽辦法</a
            >
          </li>
          <li>
            <a href="/" class="hover:text-primary transition-colors"
              >檔案下載</a
            >
          </li>
          <li>
            <a href="/" class="hover:text-primary transition-colors"
              >交通地點</a
            >
          </li>
          <li>
            <a
              href="/"
              class="hover:text-primary transition-colors"
              >報名 / 資料上傳</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-white text-lg font-bold mb-4">聯絡我們</h3>
        <ul class="space-y-4">
          <li class="flex items-center gap-3">
            <div
              class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center shrink-0"
            >
              <img
                src="/images/mail.png"
                alt="Email"
                class="w-4 h-4 object-contain opacity-80"
                style="filter: brightness(0) invert(1);"
              />
            </div>
            <!-- <a href="mailto:mcpc2026@example.edu.tw" class="hover:text-primary transition-colors">mcpc2026@example.edu.tw</a> -->
          </li>

          <li class="flex items-center gap-3">
            <div
              class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center shrink-0"
            >
              <img
                src="/images/phone.png"
                alt="Phone"
                class="w-4 h-4 object-contain opacity-80"
                style="filter: brightness(0) invert(1);"
              />
            </div>
            <span>(04) 2284-0688 分機 615</span>
          </li>

          <li class="flex items-center gap-3">
            <div
              class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center shrink-0"
            >
              <img
                src="/images/clock.png"
                alt="Hours"
                class="w-4 h-4 object-contain opacity-80"
                style="filter: brightness(0) invert(1);"
              />
            </div>
            <span>週一至週五 09:00 - 17:00</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-8 text-center text-sm text-slate-500">
      Copyright &copy; 次世代超高速傳輸系統整合教學聯盟中心 All Rights Reserved.
    </div>
  </div>
</footer>