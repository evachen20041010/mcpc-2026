---
import { downloadItems } from "../data/downloadData";
---

<section id="downloads" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-up">
      <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
        檔案下載
        <span
          class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full"
        ></span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        downloadItems.map((item) => (
          <a
            href={item.isAvailable === false ? undefined : item.href}
            download={item.isExternal ? undefined : true}
            target={item.isExternal ? "_blank" : undefined}
            rel={item.isExternal ? "noopener noreferrer" : undefined}
            aria-label={`下載 ${item.title}`}
            class:list={[
              "group flex items-center p-5 bg-white border border-slate-100 rounded-2xl shadow-sm transition-all duration-300",
              item.isAvailable === false
                ? "cursor-not-allowed opacity-60"
                : "hover:shadow-lg hover:border-primary/20 hover:-translate-y-1",
            ]}
          >
            <div class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center text-white shadow-md group-hover:scale-110 transition-transform duration-300 flex-shrink-0">
              <img
                src={item.previewSrc ?? "/downloads/poster_r2.png"}
                alt={item.title}
                class="w-full h-full object-cover rounded-xl"
              />
            </div>

            <div class="ml-5 flex-1 min-w-0">
              <h3 class="text-lg font-bold text-slate-800 truncate group-hover:text-primary transition-colors">
                {item.title}
              </h3>
              <div class="flex items-center gap-2 mt-1">
                {item.fileType && (
                  <span class="text-xs font-medium text-slate-500 uppercase bg-slate-50 px-2 py-0.5 rounded">
                    {item.fileType}
                  </span>
                )}
                {item.fileName && (
                  <span class="text-xs text-slate-400 truncate">
                    • {item.fileName}
                  </span>
                )}
              </div>
            </div>

            <div class="text-slate-300 group-hover:text-primary transition-colors duration-300 transform group-hover:translate-y-1 flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 14l-7 7m0 0l-7-7m7 7V3"
                />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
