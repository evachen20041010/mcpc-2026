---
const baseFileShape = "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z";
const baseFileFold = "M14 2v6h6";

const files = [
  { 
    title: "競賽簡章", 
    type: "PDF 格式", 
    size: "2.5 MB",
    iconColor: "bg-blue-600",
    innerIcon: "M16 13H8M16 17H8M10 9H8" 
  },
  // { 
  //   title: "參賽報名表", 
  //   type: "Word 格式", 
  //   size: "500 KB",
  //   iconColor: "bg-sky-500",
  //   innerIcon: "M16 13H8M16 17H8M10 9H8"
  // },
  // { 
  //   title: "授權書範本", 
  //   type: "PDF 格式", 
  //   size: "1.2 MB",
  //   iconColor: "bg-blue-500",
  //   innerIcon: "M9 15l2 2 4-4" 
  // },
  // { 
  //   title: "決賽簡報範本", 
  //   type: "PPT 格式", 
  //   size: "5.2 MB",
  //   iconColor: "bg-indigo-500",
  //   innerIcon: "M10 11l4 3-4 3v-6z"
  // },
  // { 
  //   title: "海報設計範本", 
  //   type: "AI 格式", 
  //   size: "12 MB",
  //   iconColor: "bg-slate-600",
  //   innerIcon: "M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-1.12-2.5-2.5-2.5S6 10.62 6 12a2.5 2.5 0 0 0 2.5 2.5z M16 14.5A2.5 2.5 0 0 0 18.5 12c0-1.38-1.12-2.5-2.5-2.5S13.5 10.62 13.5 12a2.5 2.5 0 0 0 2.5 2.5z"
  // },
];
---

<section id="downloads" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-slate-800 relative inline-block">
        檔案下載
        <span class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-12 h-1 bg-primary rounded-full"></span>
      </h2>
      <p class="text-slate-500 mt-4">請下載並詳閱相關競賽文件</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {files.map((file) => (
        <a href="#" class="group flex items-center p-5 bg-white border border-slate-100 rounded-2xl shadow-sm hover:shadow-lg hover:border-primary/20 hover:-translate-y-1 transition-all duration-300">
          
          <div class={`w-14 h-14 ${file.iconColor} rounded-xl flex items-center justify-center text-white shadow-md group-hover:scale-110 transition-transform duration-300 flex-shrink-0`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={baseFileShape} />
                <path d={baseFileFold} />
                <path d={file.innerIcon} />
            </svg>
          </div>
          
          <div class="ml-5 flex-1 min-w-0">
            <h3 class="text-lg font-bold text-slate-800 truncate group-hover:text-primary transition-colors">
              {file.title}
            </h3>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs font-medium text-slate-500 uppercase bg-slate-50 px-2 py-0.5 rounded">{file.type}</span>
              <span class="text-xs text-slate-400">• {file.size}</span>
            </div>
          </div>
          
          <div class="text-slate-300 group-hover:text-primary transition-colors duration-300 transform group-hover:translate-y-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>

        </a>
      ))}
    </div>
  </div>
</section>