---
import { downloadItems } from "../../data/downloadData";
---

<section class="pt-20">
  <section class="relative overflow-hidden bg-white border-b border-slate-200">
    <div
      class="absolute inset-0 bg-gradient-to-br from-sky-50 via-white to-slate-50"
    >
    </div>

    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20 lg:py-24"
    >
      <div class="max-w-4xl">
        <p class="text-sm font-bold tracking-[0.25em] text-primary/80 mb-4">
          DOWNLOADS
        </p>

        <h1
          class="text-4xl lg:text-5xl font-black text-slate-800 tracking-tight"
        >
          檔案下載
        </h1>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50 relative overflow-hidden min-h-[50vh]">
    <div
      class="absolute top-0 left-0 w-full h-24 bg-gradient-to-b from-white to-transparent opacity-50"
    >
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {
          downloadItems.map((item) => (
            <article class="bg-white rounded-[2rem] border border-slate-200 p-5 sm:p-6 shadow-sm hover:border-primary/30 hover:shadow-md transition-all duration-300 h-full">
              <div class="flex flex-col sm:flex-row gap-5 sm:gap-6 h-full">
                <div class="w-full sm:w-36 md:w-40 shrink-0">
                  {item.previewSrc ? (
                    <div class="overflow-hidden rounded-[1.25rem] border border-slate-200 bg-slate-50">
                      <img
                        src={item.previewSrc}
                        alt={item.title}
                        class="w-full h-auto object-cover"
                      />
                    </div>
                  ) : (
                    <div class="h-40 rounded-[1.25rem] border border-slate-200 bg-slate-50 flex items-center justify-center text-slate-400 font-bold">
                      無預覽圖
                    </div>
                  )}
                </div>

                <div class="flex-1 min-w-0 flex flex-col justify-between">
                  <div>
                    <div class="flex flex-wrap items-center gap-3 mb-3">
                      {item.fileType && (
                        <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-wide">
                          {item.fileType}
                        </span>
                      )}

                      <span class="text-sm text-slate-400 font-medium break-all">
                        {item.fileName}
                      </span>
                    </div>

                    <h3 class="text-2xl font-black text-slate-800 mb-3 leading-snug">
                      {item.title}
                    </h3>

                    {item.desc && (
                      <p class="text-slate-600 leading-relaxed mb-4">
                        {item.desc}
                      </p>
                    )}
                  </div>

                  <div class="flex justify-end pt-2 mt-auto">
                    {item.isAvailable === false ? (
                      <span class="inline-flex items-center justify-center text-slate-300 cursor-not-allowed">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="w-7 h-7"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19 14l-7 7m0 0l-7-7m7 7V3"
                          />
                        </svg>
                      </span>
                    ) : (
                      <a
                        href={item.href}
                        download={!item.isExternal}
                        target={item.isExternal ? "_blank" : undefined}
                        rel={
                          item.isExternal ? "noopener noreferrer" : undefined
                        }
                        aria-label={`下載 ${item.title}`}
                        class="inline-flex items-center justify-center text-slate-300 hover:text-primary transition-colors duration-300 transform hover:translate-y-1"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="w-7 h-7"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19 14l-7 7m0 0l-7-7m7 7V3"
                          />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</section>
