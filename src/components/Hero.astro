---
// Hero.astro - 2026 MCPC
---

<section
    id="home"
    class="relative pt-32 pb-24 lg:pt-32 lg:pb-24 min-h-[85vh] lg:min-h-[80vh] flex items-center overflow-hidden bg-slate-50 border-b border-slate-200"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div
            class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center"
        >
            <div
                class="flex flex-col justify-center text-center lg:text-left pt-8 lg:pt-0"
            >
                <div
                    class="animate-fade-up w-max px-[18px] py-[8px] bg-primary/10 text-primary rounded font-bold text-base mb-[25px] mx-auto lg:mx-0 tracking-[1px]"
                    style="animation-delay: 100ms;"
                >
                    2026 年度競賽
                </div>

                <h1
                    class="animate-fade-up text-5xl sm:text-6xl lg:text-[4.5rem] font-black text-slate-800 mb-6 leading-tight tracking-wide"
                    style="animation-delay: 200ms;"
                >
                    行動通訊<br />
                    <span
                        class="bg-gradient-to-r from-primary to-blue-500 bg-clip-text text-transparent block mt-2"
                        >實務競賽</span
                    >
                </h1>

                <p
                    class="animate-fade-up text-lg lg:text-xl text-slate-600 mb-10 leading-relaxed max-w-xl mx-auto lg:mx-0 font-medium"
                    style="animation-delay: 300ms;"
                >
                    連結智慧，驅動未來。邀請全國大專院校學生參與，展現專業實力，角逐豐厚獎金與榮譽。
                </p>

                <div
                    class="animate-fade-up flex flex-wrap gap-4 justify-center lg:justify-start"
                    style="animation-delay: 400ms;"
                >
                    <a
                        href="#registration"
                        class="px-[38px] py-[16px] bg-primary text-white rounded font-bold tracking-[1px] transition-all duration-300 shadow-[0_10px_20px_rgba(26,79,110,0.2)] hover:shadow-[0_15px_25px_rgba(26,79,110,0.3)] hover:-translate-y-[3px]"
                    >
                        立即報名 →
                    </a>
                    <a
                        href="#downloads"
                        class="px-[38px] py-[16px] bg-transparent text-primary border-2 border-primary rounded font-bold tracking-[1px] transition-all duration-300 hover:bg-primary/5"
                    >
                        下載簡章
                    </a>
                </div>
            </div>

            <div
                class="animate-fade-up relative w-full rounded-[2.5rem] bg-gradient-to-br from-[#0f2b3d] to-[#1a4f6e] p-6 sm:p-10 lg:p-12 overflow-hidden border border-slate-300"
                id="darkBlockCanvasContainer"
                style="animation-delay: 500ms;"
            >
                <canvas
                    id="innerCanvas"
                    class="absolute inset-0 w-full h-full z-0 opacity-70"
                ></canvas>

                <div class="relative z-10 pointer-events-none">
                    <div
                        class="flex items-center justify-center lg:justify-start gap-3 text-white/90 mb-8 text-base lg:text-lg tracking-widest font-bold"
                    >
                        <div
                            class="w-3 h-3 bg-sky-400 rounded-full shadow-[0_0_12px_#38bdf8] animate-pulse"
                            id="countdown-dot"
                        >
                        </div>
                        <span
                            >距離<strong
                                id="current-target-name"
                                class="text-white mx-2 font-black"
                                >載入中...</strong
                            >還有</span
                        >
                    </div>

                    <div
                        class="flex justify-between items-end border-b border-white/15 pb-8 mb-10"
                    >
                        <div class="flex-1 text-center lg:text-left">
                            <span
                                id="cd-days"
                                class="tech-font block text-4xl sm:text-5xl lg:text-6xl text-white leading-none mb-2 drop-shadow-[0_0_15px_rgba(56,189,248,0.4)]"
                                >00</span
                            >
                            <span
                                class="block text-sky-400 text-xs sm:text-sm tracking-widest uppercase font-bold"
                                >Days</span
                            >
                        </div>
                        <div class="flex-1 text-center lg:text-left">
                            <span
                                id="cd-hours"
                                class="tech-font block text-4xl sm:text-5xl lg:text-6xl text-white leading-none mb-2 drop-shadow-[0_0_15px_rgba(56,189,248,0.4)]"
                                >00</span
                            >
                            <span
                                class="block text-sky-400 text-xs sm:text-sm tracking-widest uppercase font-bold"
                                >Hours</span
                            >
                        </div>
                        <div class="flex-1 text-center lg:text-left">
                            <span
                                id="cd-mins"
                                class="tech-font block text-4xl sm:text-5xl lg:text-6xl text-white leading-none mb-2 drop-shadow-[0_0_15px_rgba(56,189,248,0.4)]"
                                >00</span
                            >
                            <span
                                class="block text-sky-400 text-xs sm:text-sm tracking-widest uppercase font-bold"
                                >Mins</span
                            >
                        </div>
                        <div class="flex-1 text-center lg:text-left">
                            <span
                                id="cd-secs"
                                class="tech-font block text-4xl sm:text-5xl lg:text-6xl text-white leading-none mb-2 drop-shadow-[0_0_15px_rgba(56,189,248,0.4)]"
                                >00</span
                            >
                            <span
                                class="block text-sky-400 text-xs sm:text-sm tracking-widest uppercase font-bold"
                                >Secs</span
                            >
                        </div>
                    </div>

                    <div
                        id="dynamic-timeline-container"
                        class="relative flex flex-col pointer-events-auto"
                    >
                        <div
                            class="v-time-card relative grid grid-cols-[20px_1fr] sm:grid-cols-[24px_1fr] gap-4 sm:gap-6 items-start pb-2"
                        >
                            <div
                                class="v-time-marker self-stretch flex flex-col items-center pt-1"
                            >
                                <div class="v-time-dot"></div>
                                <div
                                    class="v-time-segment mt-3 flex-1 min-h-[2.75rem]"
                                >
                                </div>
                            </div>
                            <div
                                class="v-time-info w-full text-white/50 animate-pulse"
                            >
                                時程同步中...
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    @import url("https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap");

    .tech-font {
        font-family: "Share Tech Mono", monospace;
    }

    @keyframes fadeUpEnter {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-up {
        opacity: 0;
        animation: fadeUpEnter 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    /* Timeline */
    .v-time-card {
        transition: opacity 0.3s ease;
    }

    .v-time-marker {
        min-height: 100%;
    }

    .v-time-dot {
        width: 14px;
        height: 14px;
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.08);
        border: 2px solid rgba(255, 255, 255, 0.28);
        transition:
            background-color 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease,
            transform 0.3s ease,
            opacity 0.3s ease;
        flex-shrink: 0;
    }

    .v-time-segment {
        width: 1px;
        border-radius: 9999px;
        background: linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.18),
            rgba(255, 255, 255, 0.08)
        );
        transition:
            background 0.3s ease,
            opacity 0.3s ease;
    }

    .v-time-info {
        transition:
            transform 0.3s ease,
            opacity 0.3s ease;
    }

    /* Active */
    .v-time-card.active-state .v-time-dot {
        background: #38bdf8 !important;
        border-color: rgba(255, 255, 255, 0.95) !important;
        box-shadow: 0 0 14px rgba(56, 189, 248, 0.75) !important;
        transform: scale(1.08);
    }

    .v-time-card.active-state .v-time-segment {
        background: linear-gradient(
            to bottom,
            rgba(56, 189, 248, 0.55),
            rgba(56, 189, 248, 0.12)
        );
    }

    .v-time-card.active-state .v-time-info {
        transform: translateX(8px);
    }

    .v-time-card.active-state .v-time-info span {
        color: white !important;
    }

    .v-time-card.active-state .v-time-info strong {
        color: #38bdf8 !important;
    }

    /* Past */
    .v-time-card.past-state {
        opacity: 0.38;
    }

    .v-time-card.past-state .v-time-dot {
        background: transparent !important;
        border-color: rgba(255, 255, 255, 0.2) !important;
        box-shadow: none !important;
    }

    .v-time-card.past-state .v-time-segment {
        background: linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.1),
            rgba(255, 255, 255, 0.04)
        );
    }

    .v-time-card.past-state .v-time-info span,
    .v-time-card.past-state .v-time-info strong {
        text-decoration: line-through;
    }
</style>

<script>
    import { db } from "../firebase/client.js";
    import { collection, getDocs, query, orderBy } from "firebase/firestore";

    document.addEventListener("DOMContentLoaded", () => {
        // ================= 1. 抓取 Firebase 日程並動態渲染 =================
        const initHeroTimeline = async () => {
            const timelineContainer = document.getElementById(
                "dynamic-timeline-container",
            );
            const targetNameEl = document.getElementById("current-target-name");

            if (!timelineContainer || !targetNameEl) return;

            type MilestoneItem = {
                id: string;
                name: string;
                timestamp: number;
                dateStr: string;
            };

            let milestones: MilestoneItem[] = [];

            try {
                const q = query(
                    collection(db, "timeline"),
                    orderBy("dateStr", "asc"),
                );
                const querySnapshot = await getDocs(q);

                querySnapshot.forEach((doc) => {
                    const data = doc.data();
                    const targetTime = new Date(
                        `${data.dateStr}T23:59:59`,
                    ).getTime();

                    milestones.push({
                        id: doc.id,
                        name: data.title,
                        timestamp: targetTime,
                        dateStr: data.dateStr.replace(/-/g, "."),
                    });
                });
            } catch (error) {
                console.error("Error loading timeline:", error);
                targetNameEl.innerText = "系統連線錯誤";
                return;
            }

            if (milestones.length === 0) {
                targetNameEl.innerText = "即將公布";
                timelineContainer.innerHTML = `<p class="text-white/50">尚無日程資訊</p>`;
                return;
            }

            const now = new Date().getTime();
            const upcoming = milestones.filter((m) => m.timestamp > now);
            const past = milestones.filter((m) => m.timestamp <= now).reverse();

            let displayItems: MilestoneItem[] = [];
            if (upcoming.length >= 3) {
                displayItems = upcoming.slice(0, 3);
            } else {
                displayItems = [...upcoming];
                const needCount = 3 - displayItems.length;
                displayItems = [
                    ...past.slice(0, needCount).reverse(),
                    ...displayItems,
                ];
            }

            const activeIndex = displayItems.findIndex(
                (m) => m.timestamp > now,
            );

            const html = displayItems
                .map((item, index) => {
                    let stateClass = "";

                    if (item.timestamp <= now) {
                        stateClass = "past-state";
                    } else if (index === activeIndex) {
                        stateClass = "active-state";
                    }

                    const isLast = index === displayItems.length - 1;
                    const cardPaddingClass = isLast ? "pb-0" : "pb-2";
                    const segmentHtml = isLast
                        ? ""
                        : `<div class="v-time-segment mt-3 flex-1 min-h-[2.75rem]"></div>`;

                    return `
                    <div class="v-time-card relative grid grid-cols-[20px_1fr] sm:grid-cols-[24px_1fr] gap-4 sm:gap-6 items-start ${cardPaddingClass} group ${stateClass}">
                        <div class="v-time-marker self-stretch flex flex-col items-center pt-1">
                            <div class="v-time-dot"></div>
                            ${segmentHtml}
                        </div>
                        <div class="v-time-info flex justify-between items-center gap-4 w-full min-w-0 transition-transform duration-300">
                            <span class="text-white/80 text-base sm:text-lg font-bold transition-colors truncate">${item.name}</span>
                            <strong class="tech-font text-xl sm:text-2xl text-white/90 tracking-wide transition-colors shrink-0">${item.dateStr}</strong>
                        </div>
                    </div>
                `;
                })
                .join("");

            timelineContainer.innerHTML = html;

            // ================= 2. 啟動倒數計時 =================
            const targetMs =
                activeIndex !== -1 ? displayItems[activeIndex] : null;

            if (targetMs) {
                targetNameEl.innerText = targetMs.name;

                const updateCountdown = setInterval(function () {
                    const distance = targetMs.timestamp - new Date().getTime();

                    if (distance <= 0) {
                        clearInterval(updateCountdown);
                        window.location.reload();
                        return;
                    }

                    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const hours = Math.floor(
                        (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
                    );
                    const minutes = Math.floor(
                        (distance % (1000 * 60 * 60)) / (1000 * 60),
                    );
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    const cdDays = document.getElementById("cd-days");
                    const cdHours = document.getElementById("cd-hours");
                    const cdMins = document.getElementById("cd-mins");
                    const cdSecs = document.getElementById("cd-secs");

                    if (cdDays)
                        cdDays.innerText =
                            days < 10 ? "0" + days : days.toString();
                    if (cdHours)
                        cdHours.innerText =
                            hours < 10 ? "0" + hours : hours.toString();
                    if (cdMins)
                        cdMins.innerText =
                            minutes < 10 ? "0" + minutes : minutes.toString();
                    if (cdSecs)
                        cdSecs.innerText =
                            seconds < 10 ? "0" + seconds : seconds.toString();
                }, 1000);
            } else {
                const cdDays = document.getElementById("cd-days");
                const cdHours = document.getElementById("cd-hours");
                const cdMins = document.getElementById("cd-mins");
                const cdSecs = document.getElementById("cd-secs");

                if (cdDays) cdDays.innerText = "00";
                if (cdHours) cdHours.innerText = "00";
                if (cdMins) cdMins.innerText = "00";
                if (cdSecs) cdSecs.innerText = "00";

                if (targetNameEl && targetNameEl.parentElement) {
                    targetNameEl.parentElement.innerHTML =
                        "本年度競賽 <strong class='text-white mx-2 font-bold'>已圓滿落幕</strong>";
                }

                const dot = document.getElementById("countdown-dot");
                if (dot) {
                    dot.style.backgroundColor = "#4CAF50";
                    dot.style.boxShadow = "0 0 12px #4CAF50";
                }
            }
        };

        initHeroTimeline();

        // ================= 3. Canvas 互動粒子 =================
        const canvasEl = document.getElementById("innerCanvas");
        const canvasContainerEl = document.getElementById(
            "darkBlockCanvasContainer",
        );

        if (!(canvasEl instanceof HTMLCanvasElement)) return;
        if (!(canvasContainerEl instanceof HTMLElement)) return;

        const canvas: HTMLCanvasElement = canvasEl;
        const canvasContainer: HTMLElement = canvasContainerEl;
        const ctxResult = canvas.getContext("2d");
        if (!ctxResult) return;

        const context: CanvasRenderingContext2D = ctxResult;

        function resizeCanvas() {
            canvas.width = canvasContainer.clientWidth;
            canvas.height = canvasContainer.clientHeight;
        }

        window.addEventListener("resize", resizeCanvas);
        resizeCanvas();

        const mouse = {
            targetX: canvas.width / 2,
            targetY: canvas.height / 2,
            x: canvas.width / 2,
            y: canvas.height / 2,
            isActive: false,
        };

        canvasContainer.addEventListener(
            "mousemove",
            function (event: MouseEvent) {
                const rect = canvasContainer.getBoundingClientRect();
                mouse.targetX = event.clientX - rect.left;
                mouse.targetY = event.clientY - rect.top;
                mouse.isActive = true;
            },
        );

        canvasContainer.addEventListener("mouseleave", function () {
            mouse.isActive = false;
        });

        canvasContainer.addEventListener(
            "touchmove",
            function (event: TouchEvent) {
                const rect = canvasContainer.getBoundingClientRect();
                mouse.targetX = event.touches[0].clientX - rect.left;
                mouse.targetY = event.touches[0].clientY - rect.top;
                mouse.isActive = true;
            },
            { passive: true },
        );

        canvasContainer.addEventListener("touchend", function () {
            mouse.isActive = false;
        });

        class Particle {
            x: number;
            y: number;
            speedX: number;
            speedY: number;
            baseSize: number;

            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.speedX = (Math.random() - 0.5) * 0.8;
                this.speedY = (Math.random() - 0.5) * 0.8;
                this.baseSize = Math.random() * 2 + 1;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;

                if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
                if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
            }

            draw() {
                const dx = this.x - mouse.x;
                const dy = this.y - mouse.y;
                const distance = Math.sqrt(dx * dx + dy * dy);
                const signalStrength =
                    mouse.isActive && distance < 200 ? 1 - distance / 200 : 0;

                const currentOpacity = 0.2 + signalStrength * 0.8;
                const currentSize = this.baseSize + signalStrength * 2;

                context.beginPath();
                context.arc(this.x, this.y, currentSize, 0, Math.PI * 2);

                if (signalStrength > 0.1) {
                    context.fillStyle = `rgba(56, 189, 248, ${currentOpacity})`;
                    context.shadowBlur = 10 * signalStrength;
                    context.shadowColor = "#38bdf8";
                } else {
                    context.fillStyle = "rgba(255, 255, 255, 0.2)";
                    context.shadowBlur = 0;
                }

                context.fill();
                context.shadowBlur = 0;
            }
        }

        const particlesArray: Particle[] = [];
        const numberOfParticles = window.innerWidth < 768 ? 30 : 60;

        for (let i = 0; i < numberOfParticles; i++) {
            particlesArray.push(new Particle());
        }

        function connect() {
            for (let a = 0; a < particlesArray.length; a++) {
                for (let b = a; b < particlesArray.length; b++) {
                    const pa = particlesArray[a];
                    const pb = particlesArray[b];
                    const distanceNodes = Math.hypot(pa.x - pb.x, pa.y - pb.y);

                    if (distanceNodes < 140) {
                        const avgDistToMouse =
                            (Math.hypot(pa.x - mouse.x, pa.y - mouse.y) +
                                Math.hypot(pb.x - mouse.x, pb.y - mouse.y)) /
                            2;

                        const baseOpacity = 1 - distanceNodes / 140;
                        const isLit = mouse.isActive && avgDistToMouse < 200;

                        if (isLit) {
                            const signalOpacity = Math.max(
                                0.1,
                                1 - avgDistToMouse / 200,
                            );
                            context.strokeStyle = `rgba(56, 189, 248, ${baseOpacity * signalOpacity * 1.5})`;
                            context.lineWidth = 0.8;
                        } else {
                            context.strokeStyle = `rgba(255, 255, 255, ${baseOpacity * 0.1})`;
                            context.lineWidth = 0.4;
                        }

                        context.beginPath();
                        context.moveTo(pa.x, pa.y);
                        context.lineTo(pb.x, pb.y);
                        context.stroke();
                    }
                }
            }
        }

        function animate() {
            context.clearRect(0, 0, canvas.width, canvas.height);

            mouse.x += (mouse.targetX - mouse.x) * 0.1;
            mouse.y += (mouse.targetY - mouse.y) * 0.1;

            particlesArray.forEach((p) => {
                p.update();
            });

            connect();

            particlesArray.forEach((p) => {
                p.draw();
            });

            requestAnimationFrame(animate);
        }

        animate();
    });
</script>
