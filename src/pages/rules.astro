---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import RulesSection from "../components/RulesSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="競賽辦法 - 2026 MCPC 行動通訊實務競賽">
  <Navbar />

  <main class="pt-20">
    <section class="relative overflow-hidden bg-white border-b border-slate-200">
      <div class="absolute inset-0 bg-gradient-to-br from-sky-50 via-white to-slate-50"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-sm font-bold tracking-[0.25em] text-primary/80 mb-4">
            RULES & DETAILS
          </p>

          <h1 class="text-4xl lg:text-5xl font-black text-slate-800 tracking-tight mb-6">
            競賽辦法
          </h1>

        </div>
      </div>
    </section>

    <RulesSection />
  </main>

  <Footer />
</Layout>
